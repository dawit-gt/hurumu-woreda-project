// ============================================================
// Hurumu Woreda Administration Portal — Prisma Schema
// Database: PostgreSQL
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ────────────────────────────────────────────────────────

enum Role {
  SUPER_ADMIN
  ADMIN
  DEPARTMENT_HEAD
  STAFF
  PUBLIC
}

enum NewsStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum NewsTag {
  ANNOUNCEMENT
  EVENT
  NOTICE
  PROJECT
  TENDER
}

enum ServiceCategory {
  CIVIL_REGISTRATION
  LAND_ADMINISTRATION
  BUSINESS_LICENSE
  AGRICULTURE
  HEALTH
  EDUCATION
  INFRASTRUCTURE
  SOCIAL_SERVICES
  FINANCE
  OTHER
}

enum DocumentType {
  BUDGET_REPORT
  PROCUREMENT_PLAN
  PERFORMANCE_REPORT
  POLICY
  GUIDELINE
  TENDER_DOCUMENT
  ANNUAL_PLAN
  OTHER
}

enum ApplicationStatus {
  PENDING
  UNDER_REVIEW
  APPROVED
  REJECTED
  REQUIRES_DOCUMENTS
}

// ─── Core: Users & Auth ──────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  fullName      String
  phone         String?
  passwordHash  String
  role          Role      @default(STAFF)
  isActive      Boolean   @default(true)
  avatarUrl     String?

  departmentId  String?
  department    Department? @relation(fields: [departmentId], references: [id])

  refreshTokens RefreshToken[]
  newsItems     News[]         @relation("NewsAuthor")
  documents     Document[]     @relation("DocumentUploader")
  auditLogs     AuditLog[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([email])
  @@index([role])
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

// ─── Organizational: Departments & Kebeles ───────────────────────

model Department {
  id          String  @id @default(cuid())
  name        String  @unique
  nameOromoo  String?
  nameAmharic String?
  slug        String  @unique
  description String?
  iconName    String?
  headName    String?
  phone       String?
  email       String?
  isActive    Boolean @default(true)
  sortOrder   Int     @default(0)

  users       User[]
  services    Service[]
  news        News[]
  documents   Document[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([slug])
}

model Kebele {
  id          String  @id @default(cuid())
  name        String  @unique
  nameOromoo  String?
  number      Int     @unique
  population  Int?
  area        Float?  // km²
  chairperson String?
  phone       String?

  serviceApplications ServiceApplication[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── Content: News & Announcements ──────────────────────────────

model News {
  id            String     @id @default(cuid())
  title         String
  titleOromoo   String?
  titleAmharic  String?
  slug          String     @unique
  excerpt       String
  content       String     // Rich text / markdown
  tag           NewsTag    @default(ANNOUNCEMENT)
  status        NewsStatus @default(DRAFT)
  isUrgent      Boolean    @default(false)
  featuredImage String?
  publishedAt   DateTime?
  viewCount     Int        @default(0)

  authorId      String
  author        User       @relation("NewsAuthor", fields: [authorId], references: [id])

  departmentId  String?
  department    Department? @relation(fields: [departmentId], references: [id])

  tags          NewsTagRelation[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([status, publishedAt])
  @@index([slug])
  @@index([tag])
}

model NewsTagRelation {
  newsId    String
  tagLabel  String
  news      News   @relation(fields: [newsId], references: [id], onDelete: Cascade)

  @@id([newsId, tagLabel])
}

// ─── Services & Applications ─────────────────────────────────────

model Service {
  id            String          @id @default(cuid())
  name          String
  nameOromoo    String?
  nameAmharic   String?
  slug          String          @unique
  description   String
  category      ServiceCategory
  iconName      String?
  fee           Float?          // in ETB
  processingDays Int?
  requiredDocs  String[]        // list of required documents
  steps         String[]        // process steps
  isOnline      Boolean         @default(false)
  isActive      Boolean         @default(true)
  sortOrder     Int             @default(0)

  departmentId  String?
  department    Department? @relation(fields: [departmentId], references: [id])

  applications  ServiceApplication[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([category])
  @@index([slug])
}

model ServiceApplication {
  id              String            @id @default(cuid())
  referenceNumber String            @unique @default(cuid())
  applicantName   String
  applicantPhone  String
  applicantEmail  String?
  description     String?
  status          ApplicationStatus @default(PENDING)
  reviewNotes     String?
  attachments     String[]          // file URLs

  serviceId       String
  service         Service @relation(fields: [serviceId], references: [id])

  kebeleId        String?
  kebele          Kebele? @relation(fields: [kebeleId], references: [id])

  submittedAt     DateTime @default(now())
  reviewedAt      DateTime?
  resolvedAt      DateTime?
  updatedAt       DateTime @updatedAt

  @@index([status])
  @@index([referenceNumber])
  @@index([serviceId])
}

// ─── Documents & Transparency ────────────────────────────────────

model Document {
  id            String       @id @default(cuid())
  title         String
  titleOromoo   String?
  description   String?
  type          DocumentType
  fileUrl       String
  fileSize      Int?         // bytes
  mimeType      String?
  fiscalYear    String?      // e.g. "2025/26"
  quarter       Int?         // 1–4
  isPublic      Boolean      @default(true)
  downloadCount Int          @default(0)

  uploadedById  String
  uploadedBy    User       @relation("DocumentUploader", fields: [uploadedById], references: [id])

  departmentId  String?
  department    Department? @relation(fields: [departmentId], references: [id])

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([type])
  @@index([isPublic])
  @@index([fiscalYear])
}

// ─── Site Config (key-value for dynamic settings) ────────────────

model SiteConfig {
  key       String @id
  value     String
  label     String?
  updatedAt DateTime @updatedAt
}

// ─── Audit Log ───────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  action     String   // e.g. "news.publish", "user.create"
  entityType String?
  entityId   String?
  before     Json?
  after      Json?
  ipAddress  String?

  userId     String?
  user       User?  @relation(fields: [userId], references: [id], onDelete: SetNull)

  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}
